{
  "name": "dev-flow",
  "description": "Local task board and agent orchestration app with SQLite-backed persistence.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "start:all": "tsx scripts/start-all.ts",
    "doctor": "tsx scripts/doctor.ts",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify.ts",
    "test": "tsx scripts/verify.ts",
    "test:agent-runs": "tsx scripts/verify-agent-runs.ts",
    "test:absolute-paths": "tsx scripts/verify-absolute-paths.ts",
    "test:gateway": "tsx tests/server/jiraAuthoringBundle.test.ts && tsx tests/server/compositeAuthoringService.test.ts && tsx tests/server/lockAndIdempotency.test.ts && tsx tests/server/adversarialLockAndIdempotency.test.ts",
    "test:import-tasks": "tsx tests/devflow/import-tasks-from-file.test.ts",
    "test:prompt-templates": "tsx scripts/verify-prompt-templates.ts",
    "test:orchestration": "tsx scripts/verify-orchestration.ts",
    "test:start-all": "tsx scripts/verify-start-all.ts",
    "test:sqlite": "tsx scripts/verify-sqlite-persistence.ts",
    "test:task-row-persistence": "tsx scripts/verify-task-row-persistence.ts",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "mcp": "tsx mcp-server.ts",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts",
    "migrate:json": "tsx scripts/migrate-json-to-sqlite.ts",
    "smoke-multi-sse": "node scripts/smoke-multi-sse.mjs",
    "test:dvf-0224": "tsx scripts/verify-dvf-0224.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
